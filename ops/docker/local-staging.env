# Local Docker staging simulator — never use these values in production.
NODE_ENV=development
PORT=3000

ASTRANULL_PERSISTENCE_MODE=postgres
ASTRANULL_AUTH_MODE=dev-headers
ASTRANULL_PROBE_MODE=signed-worker
ASTRANULL_HIGH_SCALE_ADAPTER_MODE=dry-run
ASTRANULL_AGENT_IDENTITY_MODE=bearer
ASTRANULL_WAF_POSTURE_ENABLED=1
ASTRANULL_CONNECTORS_ENABLED=0

ASTRANULL_SECRET_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
ASTRANULL_SESSION_SECRET=local-staging-session-secret-32chars!!
ASTRANULL_PROBE_WORKER_SECRET=local-staging-probe-worker-secret-32c

ASTRANULL_LOCAL_PG_PORT=54329
ASTRANULL_LOCAL_STAGING_BASE_URL=http://127.0.0.1:3000
ASTRANULL_LOCAL_STAGING_ENVIRONMENT=local-staging
ASTRANULL_LOCAL_STAGING_RELEASE_ID=rel-local-staging-2026-07-03