# Railway hosted-staging (customer production-like). Link Postgres first.
NODE_ENV=production
PORT=3000

ASTRANULL_DATABASE_URL=${{Postgres.DATABASE_URL}}
ASTRANULL_PERSISTENCE_MODE=postgres
ASTRANULL_DEPLOYMENT_PROFILE=hosted-staging

# Bundled staging OIDC fixture (HTTPS JWKS served from /.well-known/jwks.json)
ASTRANULL_BUNDLED_STAGING_OIDC=1
ASTRANULL_AUTH_MODE=oidc-jwt
# Issuer/JWKS default from RAILWAY_PUBLIC_DOMAIN when unset
ASTRANULL_PUBLIC_LOGIN_URL=/login

# Production-like safe paths (no dry-run high-scale adapter, signed probe worker)
ASTRANULL_PROBE_MODE=signed-worker
ASTRANULL_PROBE_WORKER_SECRET=hosted-staging-probe-worker-secret-32c
ASTRANULL_PROBE_TENANT_ID=ten_demo
ASTRANULL_HIGH_SCALE_ADAPTER_MODE=disabled
ASTRANULL_AGENT_IDENTITY_MODE=bearer

ASTRANULL_SECRET_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
ASTRANULL_WAF_POSTURE_ENABLED=1
ASTRANULL_CONNECTORS_ENABLED=0