# Runtime secrets — set in DigitalOcean App Platform → web → Environment Variables.
# Never commit real values. Generate with:
#   openssl rand -hex 32   # ASTRANULL_SECRET_ENCRYPTION_KEY
#   openssl rand -hex 24   # ASTRANULL_PROBE_WORKER_SECRET

ASTRANULL_SECRET_ENCRYPTION_KEY=<64-hex-chars>
ASTRANULL_PROBE_WORKER_SECRET=<32+-char-secret>

# Non-secret defaults are in app.yaml. Override only if needed:
# ASTRANULL_PUBLIC_BASE_URL=https://astranull.site
# ASTRANULL_PROBE_TENANT_ID=ten_demo